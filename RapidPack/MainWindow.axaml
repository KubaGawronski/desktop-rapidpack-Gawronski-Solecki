<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="RapidPack.MainWindow"
        Title="RapidPack">
        <Grid Background="#121212">
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="400">

            <Border Background="#1e1e1e"
                    Padding="24"
                    CornerRadius="10"
                    BorderBrush="#333"
                    BorderThickness="1">

                <StackPanel Spacing="10">

                    <TextBlock Text="RapidPack 📦"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Wysokość"/>
                    <TextBox x:Name="WysokoscTextBox" InnerRightContent="cm"/>

                    <TextBlock Text="Szerokość"/>
                    <TextBox x:Name="SzerokoscTextBox" InnerRightContent="cm"/>

                    <TextBlock Text="Głębokość"/>
                    <TextBox x:Name="GlebokoscTextBox" InnerRightContent="cm"/>

                    <TextBlock Text="Waga"/>
                    <TextBox x:Name="WagaTextBox" InnerRightContent="kg"/>

                    <TextBlock x:Name="ShowWeightErrorTextBox"
                               Foreground="Red"/>

                    <CheckBox x:Name="WysylkaCheckBox"
                              Content="Ekspres (+15 zł)"/>

                    <TextBlock Text="Typ przesyłki"/>
                    <ComboBox x:Name="TypPrzesylkiComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="Standardowa"/>
                        <ComboBoxItem Content="Ostrożnie (szkło)"/>
                        <ComboBoxItem Content="Paleta"/>
                    </ComboBox>

                    <TextBlock x:Name="PriceTextBlock"
                               FontSize="18"
                               Margin="0,10,0,0"/>

                    <Button x:Name="SubmitButton"
                            Content="Wyceń"
                            Height="40"
                            Background="#3a86ff"
                            Foreground="White"
                            CornerRadius="6"/>

                    <TextBlock x:Name="SummaryTextBlock"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
